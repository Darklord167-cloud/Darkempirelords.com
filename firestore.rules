rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Validates if an ID is generally sane
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    match /users/{userId}/private/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId && isValidId(document);
    }
    
    match /bot_states/{botId} {
      // Only allow if authenticated and botId is valid; ideally we would restrict this
      // to the specific owner, but since user structure is loose, we at least validate the schema and ID.
      allow read: if request.auth != null && isValidId(botId);
      allow write: if request.auth != null && isValidId(botId) && request.resource.data.keys().hasAll(['status']);
    }
  }
}
